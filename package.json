{
  "name": "session-viewer",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"pnpm run dev:api\" \"pnpm run dev:fe\"",
    "dev:api": "node server.js",
    "dev:fe": "pnpm --filter session-viewer-frontend dev",
    "build": "pnpm --filter session-viewer-frontend build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2"
  }
}
